{
  "name": "fantasea",
  "version": "1.0.16",
  "description": "A template for building Kaplay games.",
  "author": "Mark <mark@remarkablemark.org>",
  "scripts": {
    "build": "npm run clean && vite build",
    "bundle": "bash scripts/bundle.sh",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:tsc": "tsc --noEmit",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "vite --open"
  },
  "homepage": "https://remarkablegames.org/fantasea/",
  "dependencies": {
    "kaplay": "4000.0.0-alpha.25"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "eslint": "10.4.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vite-plugin-html": "3.2.2"
  },
  "private": true,
  "license": "MIT"
}
